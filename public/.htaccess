<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Never serve index.html for a removed hashed asset. Returning HTML for a
  # JavaScript request causes a MIME error and leaves the SPA as a white page.
  RewriteCond %{REQUEST_URI} ^/assets/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ - [R=404,L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Powered-By "Hostinger Horizons"

  # HTML and SPA routes must always revalidate so deployments cannot keep an
  # old index that points to deleted asset hashes.
  Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  Header always set Pragma "no-cache"
  Header always set Expires "0"

  # Vite assets include a content hash and are safe to cache permanently.
  <If "%{REQUEST_URI} =~ m#^/assets/.*$#">
    Header always set Cache-Control "public, max-age=31536000, immutable"
    Header always unset Pragma
    Header always unset Expires
  </If>
</IfModule>
